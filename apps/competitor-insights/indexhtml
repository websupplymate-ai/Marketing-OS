/* ============== CUSTOMERS / LEADS VIEW ============== */
function renderCustomers(){
  const main = document.getElementById('main');
  main.innerHTML = `
    <div class="topbar"><div><h1 class="page-title">Customers / leads</h1>
      <p class="muted" style="margin:4px 0 0;font-size:13px;"><span class="num">${marketTotals.uniqueCompanies}</span> companies across all sources</p></div></div>
    <div class="search-bar">
      <input id="lead-search" placeholder="Search company or industry" style="flex:1;" value="${leadFilter.search}" />
      <select id="lead-priority" style="width:160px;">
        <option value="all">All priorities</option>
        <option value="High">High</option>
        <option value="Medium">Medium</option>
        <option value="Low">Low</option>
      </select>
    </div>
    <div class="card" style="padding:0;overflow:auto;">
      <table>
        <thead><tr>
          <th data-key="displayName">Company</th><th data-key="industry">Industry</th>
          <th data-key="competitorsSelling">Sources</th><th data-key="totalPurchases">Total purchases</th>
          <th data-key="avgInvoice">Avg invoice</th><th data-key="growthPct">Growth</th>
          <th data-key="predictedNextPurchase">Predicted next</th><th data-key="leadScore">Lead score</th>
          <th data-key="priority">Priority</th><th data-key="status">Status</th>
        </tr></thead>
        <tbody id="lead-body"></tbody>
      </table>
    </div>
  `;
  document.getElementById('lead-priority').value = leadFilter.priority;
  document.getElementById('lead-search').oninput = e=>{ leadFilter.search = e.target.value; renderLeadRows(); };
  document.getElementById('lead-priority').onchange = e=>{ leadFilter.priority = e.target.value; renderLeadRows(); };
  document.querySelectorAll('th[data-key]').forEach(th=>{
    th.onclick = ()=>{
      const key = th.dataset.key;
      leadSort.dir = (leadSort.key===key && leadSort.dir==='desc') ? 'asc' : 'desc';
      leadSort.key = key;
      renderLeadRows();
    };
  });
  renderLeadRows();
}

function renderLeadRows(){
  const tbody = document.getElementById('lead-body');
  if(!tbody) return;
  let rows = Object.values(companyMaster);
  if(leadFilter.priority!=='all') rows = rows.filter(c=>c.priority===leadFilter.priority);
  if(leadFilter.search) rows = rows.filter(c=> (c.displayName+c.industry).toLowerCase().includes(leadFilter.search.toLowerCase()));
  rows.sort((a,b)=>{
    let av=a[leadSort.key], bv=b[leadSort.key];
    if(leadSort.key==='competitorsSelling'){ av=a.competitorsSelling.size; bv=b.competitorsSelling.size; }
    if(av instanceof Date) { av=av.getTime(); bv=bv.getTime(); }
    if(typeof av==='string'){ av=av.toLowerCase(); bv=bv.toLowerCase(); }
    if(av<bv) return leadSort.dir==='asc'?-1:1;
    if(av>bv) return leadSort.dir==='asc'?1:-1;
    return 0;
  });
  tbody.innerHTML = rows.slice(0,200).map(c=>`
    <tr>
      <td>${c.displayName}</td>
      <td class="muted">${c.industry}</td>
      <td>${[...c.competitorsSelling].map(s=>`<span class="badge-competitor">${s}</span>`).join('')}</td>
      <td class="num">${fmtCurrency(c.totalPurchases)}</td>
      <td class="num">${fmtCurrency(c.avgInvoice)}</td>
      <td class="num" style="color:${c.growthPct>=0?'var(--secondary)':'var(--danger)'};">${c.growthPct>=0?'+':''}${c.growthPct.toFixed(0)}%</td>
      <td class="num">${fmtDate(c.predictedNextPurchase)}</td>
      <td class="num">${c.leadScore}</td>
      <td><span class="pill pill-${c.priority.toLowerCase()}">${c.priority}</span></td>
      <td class="muted">${c.status}</td>
    </tr>
  `).join('');
}

/* ============== FORECASTING VIEW ============== */
function renderForecasting(){
  const main = document.getElementById('main');
  const now = new Date();
  const upcoming = Object.values(companyMaster)
    .filter(c=> c.predictedNextPurchase >= new Date(now-7*86400000))
    .sort((a,b)=>a.predictedNextPurchase-b.predictedNextPurchase)
    .slice(0,100);
  main.innerHTML = `
    <div class="topbar"><div><h1 class="page-title">Forecasting</h1>
      <p class="muted" style="margin:4px 0 0;font-size:13px;">Expected reorder windows, ranked by date</p></div></div>
    <div class="card" style="padding:0;overflow:auto;">
      <table>
        <thead><tr><th>Company</th><th>Last purchase</th><th>Avg gap (days)</th><th>Expected purchase</th>
          <th>Expected amount</th><th>Lead score</th></tr></thead>
        <tbody>${upcoming.map(c=>`
          <tr><td>${c.displayName}</td><td class="muted num">${fmtDate(c.lastPurchase)}</td>
            <td class="muted num">${Math.round(c.avgGapDays)}</td><td class="num">${fmtDate(c.predictedNextPurchase)}</td>
            <td class="num">${fmtCurrency(c.avgInvoice)}</td><td class="num">${c.leadScore}</td></tr>
        `).join('')}</tbody>
      </table>
    </div>
  `;
}

/* ============== EXPORT ============== */
function exportCSV(){
  const headers = ['Company','GST','Industry','Location','Total Purchases','Avg Invoice','Frequency (per yr)',
    'Last Purchase','Predicted Next Purchase','Growth %','Lead Score','Priority','Status','Sources'];
  const rows = Object.values(companyMaster).map(c=>[
    c.displayName, c.gst, c.industry, c.location, c.totalPurchases.toFixed(2), c.avgInvoice.toFixed(2),
    c.frequency.toFixed(2), fmtDate(c.lastPurchase), fmtDate(c.predictedNextPurchase), c.growthPct.toFixed(1),
    c.leadScore, c.priority, c.status, [...c.competitorsSelling].join('|')
  ]);
  const csv = [headers, ...rows].map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'company_master.csv';
  a.click();
}

/* ============== RENDER ROUTER ============== */
function render(){
  renderNav();
  if(currentView==='upload') renderUpload();
  else if(currentView==='executive') renderExecutive();
  else if(currentView==='competitors') renderCompetitors();
  else if(currentView==='customers') renderCustomers();
  else if(currentView==='suppliers') renderSuppliers();
  else if(currentView==='forecasting') renderForecasting();
}
initTheme();
render();
</script>
