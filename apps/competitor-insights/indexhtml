<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SupplyMate — Market Intelligence Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root, [data-theme="light"]{
    --bg:#FFFFFF; --surface:#FFFFFF; --surface-2:#F7F9FC;
    --ink:#10151D; --ink-soft:#6B7686; --ink-muted:#8B95A3;
    --border:#E5E9EF; --border-strong:#D6DCE5;
    --primary:#1B4F8C; --primary-tint:#EAF2FF;
    --secondary:#2F8F5B; --secondary-tint:#E7F6EC;
    --danger:#A3372D; --danger-tint:#FBEAE8;
    --warning:#8A5A0B; --warning-tint:#FBF1DF;
  }
  [data-theme="dark"]{
    --bg:#0E141C; --surface:#141C27; --surface-2:#192230;
    --ink:#F2F5F9; --ink-soft:#8B97A8; --ink-muted:#67738A;
    --border:#243042; --border-strong:#2E3C52;
    --primary:#4A90D9; --primary-tint:#1A2533;
    --secondary:#52C57F; --secondary-tint:#16271E;
    --danger:#E08178; --danger-tint:#2A1A19;
    --warning:#E0B567; --warning-tint:#2A2114;
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--ink);font-size:14px;
    font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;transition:background 0.15s,color 0.15s;}
  h1,h2,h3,p,span,td,th,label{font-family:inherit;}
  .num{font-family:'IBM Plex Mono',monospace;font-variant-numeric:tabular-nums;}
  button{font:inherit;font-weight:500;cursor:pointer;border:1px solid var(--border-strong);background:var(--surface);
    border-radius:6px;padding:8px 14px;color:var(--ink);transition:background 0.1s;}
  button:hover{background:var(--surface-2);}
  button.primary{background:var(--primary);color:#fff;border-color:var(--primary);}
  button.primary:hover{filter:brightness(1.08);}
  button.secondary{background:var(--secondary);color:#fff;border-color:var(--secondary);}
  button.secondary:hover{filter:brightness(1.08);}
  button:disabled{opacity:0.4;cursor:not-allowed;}
  input,select{font:inherit;padding:8px 10px;border:1px solid var(--border-strong);border-radius:6px;
    background:var(--surface);color:var(--ink);width:100%;}
  table{width:100%;border-collapse:collapse;font-size:13px;}
  th{text-align:left;padding:8px 10px;color:var(--ink-soft);font-weight:500;border-bottom:1px solid var(--border-strong);
    cursor:pointer;white-space:nowrap;}
  td{padding:8px 10px;border-bottom:1px solid var(--border);}
  tr:hover td{background:var(--surface-2);}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;}
  .pill{display:inline-block;padding:2px 9px;border-radius:99px;font-size:11px;font-weight:500;}
  .pill-high{background:var(--danger-tint);color:var(--danger);}
  .pill-medium{background:var(--warning-tint);color:var(--warning);}
  .pill-low{background:var(--surface-2);color:var(--ink-soft);}
  .icon-box{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;}
  .icon-box.blue{background:var(--primary-tint);color:var(--primary);}
  .icon-box.green{background:var(--secondary-tint);color:var(--secondary);}
  #app{display:flex;min-height:100vh;}
  #sidebar{width:220px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);padding:20px 0;display:flex;flex-direction:column;}
  #sidebar .brand{padding:0 20px;margin-bottom:24px;font-size:15px;font-weight:600;color:var(--ink);}
  #sidebar .brand span{color:var(--primary);}
  .navitem{display:flex;align-items:center;gap:10px;padding:9px 20px;font-size:13px;font-weight:500;cursor:pointer;color:var(--ink-soft);}
  .navitem:hover{color:var(--ink);background:var(--surface-2);}
  .navitem.active{background:var(--primary-tint);color:var(--primary);}
  .navitem.disabled{opacity:0.35;pointer-events:none;}
  .theme-toggle{display:flex;align-items:center;gap:8px;margin:16px 20px 0;padding-top:16px;border-top:1px solid var(--border);}
  .theme-switch{position:relative;width:38px;height:20px;border-radius:99px;background:var(--border-strong);cursor:pointer;flex-shrink:0;}
  .theme-switch .knob{position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:var(--surface);transition:left 0.15s;}
  [data-theme="dark"] .theme-switch{background:var(--primary);}
  [data-theme="dark"] .theme-switch .knob{left:20px;}
  #main{flex:1;min-width:0;padding:24px 32px;}
  .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
  h1.page-title{font-size:18px;font-weight:600;margin:0;}
  .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px;}
  .kpi-label{font-size:12px;color:var(--ink-soft);margin:0;font-weight:500;}
  .kpi-value{font-size:24px;font-weight:600;margin:4px 0 0;}
  .grid-2{display:grid;grid-template-columns:1.2fr 1fr;gap:14px;margin-bottom:20px;}
  .chart-wrap{position:relative;width:100%;height:220px;}
  .upload-row{display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:end;margin-bottom:1rem;}
  .field label{font-size:12px;color:var(--ink-soft);font-weight:500;display:block;margin-bottom:4px;}
  .map-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:10px 0;}
  .ds-row{display:flex;align-items:center;justify-content:space-between;padding:8px 10px;border:1px solid var(--border);border-radius:6px;margin-bottom:6px;font-size:13px;}
  .muted{color:var(--ink-soft);}
  .search-bar{display:flex;gap:10px;margin-bottom:12px;}
  .badge-competitor{display:inline-block;background:var(--primary-tint);color:var(--primary);font-size:11px;font-weight:500;padding:2px 8px;border-radius:99px;margin-right:4px;}
  .sheet-tag{display:inline-block;font-size:10px;font-weight:600;padding:1px 7px;border-radius:99px;margin-left:6px;}
  .sheet-tag.sale{background:var(--secondary-tint);color:var(--secondary);}
  .sheet-tag.purchase{background:var(--primary-tint);color:var(--primary);}
</style>
</head>
<body>
<div id="app">
  <div id="sidebar">
    <div class="brand">Supply<span>Mate</span></div>
    <div id="nav"></div>
    <div class="theme-toggle">
      <div class="theme-switch" id="theme-switch"><div class="knob"></div></div>
      <span class="muted" style="font-size:12px;" id="theme-label">Light mode</span>
    </div>
  </div>
  <div id="main"></div>
</div>

<script>
/* ============== THEME ============== */
function applyTheme(t){
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('supplymate-theme', t);
  document.getElementById('theme-label').textContent = t==='dark' ? 'Dark mode' : 'Light mode';
}
function initTheme(){
  const saved = localStorage.getItem('supplymate-theme');
  applyTheme(saved === 'dark' ? 'dark' : 'light');
  document.getElementById('theme-switch').onclick = ()=>{
    const cur = document.documentElement.getAttribute('data-theme');
    applyTheme(cur==='dark' ? 'light' : 'dark');
  };
}

/* ============== STATE ============== */
let datasets = [];        // {competitorName, type:'sale'|'purchase', fileName, sheetName, rows}
let pendingFile = null;   // {competitorName, fileName, sheets:[{name, headers, rawRows, detectedType}]}
let companyMaster = {};
let supplierMaster = {};
let competitorStats = {};
let marketTotals = {};
let monthlyTrend = [];
let processed = false;
let currentView = 'upload';
let selectedCompetitor = null;
let leadSort = {key:'leadScore', dir:'desc'};
let leadFilter = {priority:'all', search:''};

const NAV_ITEMS = [
  {id:'upload', icon:'⬆', label:'Upload data', requiresData:false},
  {id:'executive', icon:'◧', label:'Executive', requiresData:true},
  {id:'competitors', icon:'◫', label:'Competitors', requiresData:true},
  {id:'customers', icon:'◔', label:'Customers / leads', requiresData:true},
  {id:'suppliers', icon:'▤', label:'Suppliers', requiresData:true},
  {id:'forecasting', icon:'↗', label:'Forecasting', requiresData:true},
];

/* ============== NAV ============== */
function renderNav(){
  const nav = document.getElementById('nav');
  nav.innerHTML = '';
  NAV_ITEMS.forEach(item=>{
    const el = document.createElement('div');
    el.className = 'navitem' + (currentView===item.id?' active':'') + ((item.requiresData && !processed)?' disabled':'');
    el.innerHTML = '<span>'+item.icon+'</span>'+item.label;
    el.onclick = ()=>{ currentView=item.id; render(); };
    nav.appendChild(el);
  });
}

/* ============== FILE PARSING (multi-sheet aware) ============== */
function guessColumn(headers, candidates){
  const lower = headers.map(h=>h.toLowerCase().trim());
  for(const c of candidates){
    const idx = lower.findIndex(h=>h.includes(c));
    if(idx>-1) return headers[idx];
  }
  return '';
}

function detectSheetType(name){
  const n = name.trim().toLowerCase();
  if(n.startsWith('p')) return 'purchase';
  if(n.startsWith('s')) return 'sale';
  return 'sale';
}

function parseFile(file, callback){
  const ext = file.name.split('.').pop().toLowerCase();
  if(ext==='csv'){
    Papa.parse(file, {header:true, skipEmptyLines:true, complete: res=>{
      callback([{name:'data', detectedType:'sale', headers:res.meta.fields, rawRows:res.data}]);
    }});
  } else {
    const reader = new FileReader();
    reader.onload = e=>{
      const wb = XLSX.read(new Uint8Array(e.target.result), {type:'array'});
      const sheets = wb.SheetNames.map(name=>{
        const json = XLSX.utils.sheet_to_json(wb.Sheets[name], {defval:''});
        return {name, detectedType: detectSheetType(name), headers: json.length?Object.keys(json[0]):[], rawRows: json};
      }).filter(s=>s.rawRows.length>0);
      callback(sheets);
    };
    reader.readAsArrayBuffer(file);
  }
}

function parseDate(val){
  if(!val) return null;
  if(val instanceof Date) return val;
  let d = new Date(val);
  if(!isNaN(d)) return d;
  const parts = String(val).split(/[\/\-\.]/);
  if(parts.length===3){
    let [a,b,c] = parts.map(p=>parseInt(p,10));
    if(c<100) c+=2000;
    d = new Date(c,b-1,a);
    if(!isNaN(d)) return d;
  }
  return null;
}

/* ============== UPLOAD VIEW ============== */
function renderUpload(){
  const main = document.getElementById('main');
  main.innerHTML = `
    <div class="topbar">
      <div>
        <h1 class="page-title">Upload data</h1>
        <p class="muted" style="margin:4px 0 0;font-size:13px;">Add a file per competitor. If it has sheets named with "p" (purchase) and "s" (sale), both are detected automatically.</p>
      </div>
    </div>
    <div class="card" style="margin-bottom:16px;">
      <div class="upload-row">
        <div class="field"><label>Competitor name</label><input id="ds-name" placeholder="e.g. Competitor A" /></div>
        <div class="field"><label>File (.csv, .xlsx, .xls)</label><input id="ds-file" type="file" accept=".csv,.xlsx,.xls" /></div>
        <button class="primary" id="ds-parse-btn">Parse file</button>
      </div>
      <div id="mapping-zone"></div>
    </div>
    <div class="card" style="margin-bottom:16px;">
      <p style="font-weight:600;margin:0 0 8px;">Datasets added (${datasets.length})</p>
      <div id="ds-list">${datasets.length===0 ? '<p class="muted" style="font-size:13px;">No datasets added yet.</p>' : ''}</div>
    </div>
    <button class="primary" id="process-btn" ${datasets.length===0?'disabled':''}>Process all data and build dashboard</button>
  `;

  const dsList = document.getElementById('ds-list');
  datasets.forEach((d,i)=>{
    const row = document.createElement('div');
    row.className = 'ds-row';
    row.innerHTML = `<span><strong>${d.competitorName}</strong> &middot; ${d.fileName} (${d.sheetName})
      <span class="sheet-tag ${d.type}">${d.type==='sale'?'Sale':'Purchase'}</span> &middot; <span class="num">${d.rows.length}</span> rows</span>`;
    const rm = document.createElement('button');
    rm.textContent = 'Remove';
    rm.onclick = ()=>{ datasets.splice(i,1); renderUpload(); };
    row.appendChild(rm);
    dsList.appendChild(row);
  });

  document.getElementById('ds-parse-btn').onclick = ()=>{
    const name = document.getElementById('ds-name').value.trim();
    const file = document.getElementById('ds-file').files[0];
    if(!name){ alert('Enter a competitor name first.'); return; }
    if(!file){ alert('Choose a file first.'); return; }
    parseFile(file, (sheets)=>{
      pendingFile = {competitorName:name, fileName:file.name, sheets};
      renderMapping();
    });
  };

  document.getElementById('process-btn').onclick = processAllData;
}

function renderMapping(){
  const zone = document.getElementById('mapping-zone');
  if(!pendingFile){ zone.innerHTML=''; return; }
  zone.innerHTML = `<p style="font-size:13px;font-weight:600;margin:14px 0 4px;">
    ${pendingFile.fileName} &mdash; ${pendingFile.sheets.length} sheet(s) detected</p>
    <div id="sheet-forms"></div>
    <button class="primary" id="confirm-map-btn" style="margin-top:8px;">Add ${pendingFile.sheets.length>1?'these datasets':'this dataset'}</button>`;

  const formsZone = document.getElementById('sheet-forms');
  pendingFile.sheets.forEach((s,idx)=>{
    const h = s.headers;
    const guess = {
      company: guessColumn(h, ['company','buyer','customer','supplier','vendor','name','party']),
      gst: guessColumn(h, ['gst','tax id','gstin']),
      amount: guessColumn(h, ['amount','invoice value','total','value']),
      date: guessColumn(h, ['date','invoice date','month']),
      industry: guessColumn(h, ['industry','sector','category']),
      location: guessColumn(h, ['location','city','state','district']),
    };
    const opts = (sel)=> h.map(f=>`<option value="${f}" ${f===sel?'selected':''}>${f}</option>`).join('') + `<option value="">— none —</option>`;
    const wrap = document.createElement('div');
    wrap.style.cssText = 'border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:10px;';
    wrap.innerHTML = `
      <p style="font-size:13px;font-weight:600;margin:0 0 8px;">Sheet "${s.name}"
        <span class="sheet-tag ${s.detectedType}">${s.detectedType==='sale'?'Sale data':'Purchase data'}</span>
        <span class="muted" style="font-weight:400;"> &middot; ${s.rawRows.length} rows</span></p>
      <div class="field" style="max-width:220px;margin-bottom:8px;">
        <label>Sheet type</label>
        <select data-role="type" data-idx="${idx}">
          <option value="sale" ${s.detectedType==='sale'?'selected':''}>Sale (competitor → customer)</option>
          <option value="purchase" ${s.detectedType==='purchase'?'selected':''}>Purchase (competitor → supplier)</option>
        </select>
      </div>
      <div class="map-grid">
        <div class="field"><label>Party name (required)</label><select data-role="company" data-idx="${idx}">${opts(guess.company)}</select></div>
        <div class="field"><label>GST / tax ID</label><select data-role="gst" data-idx="${idx}">${opts(guess.gst)}</select></div>
        <div class="field"><label>Amount (required)</label><select data-role="amount" data-idx="${idx}">${opts(guess.amount)}</select></div>
        <div class="field"><label>Date (required)</label><select data-role="date" data-idx="${idx}">${opts(guess.date)}</select></div>
        <div class="field"><label>Industry</label><select data-role="industry" data-idx="${idx}">${opts(guess.industry)}</select></div>
        <div class="field"><label>Location</label><select data-role="location" data-idx="${idx}">${opts(guess.location)}</select></div>
      </div>
    `;
    formsZone.appendChild(wrap);
  });

  document.getElementById('confirm-map-btn').onclick = ()=>{
    pendingFile.sheets.forEach((s,idx)=>{
      const get = role => document.querySelector(`[data-role="${role}"][data-idx="${idx}"]`).value;
      const type = get('type');
      const m = {company:get('company'), gst:get('gst'), amount:get('amount'), date:get('date'), industry:get('industry'), location:get('location')};
      if(!m.company || !m.amount || !m.date){ alert(`Sheet "${s.name}": party, amount, and date are required.`); return; }
      const rows = s.rawRows.map(r=>({
        company: String(r[m.company]||'').trim(),
        gst: m.gst ? String(r[m.gst]||'').trim().toUpperCase() : '',
        amount: parseFloat(String(r[m.amount]).replace(/[^0-9.\-]/g,'')) || 0,
        date: parseDate(r[m.date]),
        industry: m.industry ? String(r[m.industry]||'').trim() : 'Unknown',
        location: m.location ? String(r[m.location]||'').trim() : 'Unknown',
        competitor: pendingFile.competitorName,
      })).filter(r=> r.company && r.date && r.amount>0);
      datasets.push({competitorName: pendingFile.competitorName, type, fileName: pendingFile.fileName, sheetName: s.name, rows});
    });
    pendingFile = null;
    renderUpload();
  };
}

/* ============== PROCESSING ENGINE ============== */
function processAllData(){
  companyMaster = {};
  supplierMaster = {};
  competitorStats = {};
  const saleRows = datasets.filter(d=>d.type==='sale').flatMap(d=>d.rows);
  const purchaseRows = datasets.filter(d=>d.type==='purchase').flatMap(d=>d.rows);

  saleRows.forEach(r=>{
    const key = r.gst || r.company.toUpperCase().replace(/\s+/g,' ');
    if(!companyMaster[key]){
      companyMaster[key] = {displayName:r.company, gst:r.gst, industry:r.industry||'Unknown',
        location:r.location||'Unknown', competitorsSelling:new Set(), transactions:[]};
    }
    const c = companyMaster[key];
    c.competitorsSelling.add(r.competitor);
    c.transactions.push({competitor:r.competitor, amount:r.amount, date:r.date});
    if(r.industry && r.industry!=='Unknown') c.industry = r.industry;
    if(r.location && r.location!=='Unknown') c.location = r.location;
  });

  const now = new Date();
  let maxAvgInvoice = 1;
  Object.values(companyMaster).forEach(c=>{
    c.transactions.sort((a,b)=>a.date-b.date);
    c.count = c.transactions.length;
    c.totalPurchases = c.transactions.reduce((s,t)=>s+t.amount,0);
    c.avgInvoice = c.totalPurchases / c.count;
    if(c.avgInvoice>maxAvgInvoice) maxAvgInvoice = c.avgInvoice;
    c.firstPurchase = c.transactions[0].date;
    c.lastPurchase = c.transactions[c.count-1].date;
    const daySpan = Math.max((c.lastPurchase-c.firstPurchase)/86400000, 1);
    c.frequency = c.count>1 ? c.count/(daySpan/365) : 1;
    const gaps = [];
    for(let i=1;i<c.count;i++) gaps.push((c.transactions[i].date - c.transactions[i-1].date)/86400000);
    c.avgGapDays = gaps.length ? gaps.reduce((s,g)=>s+g,0)/gaps.length : 90;
    c.predictedNextPurchase = new Date(c.lastPurchase.getTime() + c.avgGapDays*86400000);
    const mid = Math.floor(c.count/2) || 1;
    const firstHalf = c.transactions.slice(0,mid).reduce((s,t)=>s+t.amount,0);
    const secondHalf = c.transactions.slice(mid).reduce((s,t)=>s+t.amount,0);
    c.growthPct = firstHalf>0 ? ((secondHalf-firstHalf)/firstHalf)*100 : 0;
    c.daysSinceLast = (now - c.lastPurchase)/86400000;
    c.status = c.daysSinceLast > c.avgGapDays*2 ? 'At risk' : c.daysSinceLast > c.avgGapDays ? 'Due soon' : 'Active';
  });

  Object.values(companyMaster).forEach(c=>{
    const recency = clamp(100 - c.daysSinceLast*100/180, 0, 100);
    const frequency = clamp(c.frequency*100/12, 0, 100);
    const monetary = clamp(c.avgInvoice/maxAvgInvoice*100, 0, 100);
    const growth = clamp(50 + c.growthPct/2, 0, 100);
    c.leadScore = Math.round(0.3*recency + 0.25*frequency + 0.25*monetary + 0.2*growth);
    c.priority = c.leadScore>=75 ? 'High' : c.leadScore>=50 ? 'Medium' : 'Low';
  });

  purchaseRows.forEach(r=>{
    const key = r.competitor + '::' + (r.gst || r.company.toUpperCase());
    if(!supplierMaster[key]){
      supplierMaster[key] = {competitor:r.competitor, displayName:r.company, gst:r.gst,
        industry:r.industry||'Unknown', location:r.location||'Unknown', transactions:[]};
    }
    supplierMaster[key].transactions.push({amount:r.amount, date:r.date});
  });
  Object.values(supplierMaster).forEach(s=>{
    s.transactions.sort((a,b)=>a.date-b.date);
    s.count = s.transactions.length;
    s.totalSpend = s.transactions.reduce((sum,t)=>sum+t.amount,0);
    s.avgInvoice = s.totalSpend / s.count;
    s.lastPurchase = s.transactions[s.count-1].date;
  });

  const competitorNames = new Set([...datasets.map(d=>d.competitorName)]);
  competitorNames.forEach(name=>{
    const rows = saleRows.filter(r=>r.competitor===name);
    const companiesSet = new Set(rows.map(r=> r.gst || r.company.toUpperCase()));
    const revenue = rows.reduce((s,r)=>s+r.amount,0);
    const sorted = [...rows].sort((a,b)=>a.date-b.date);
    const mid = Math.floor(sorted.length/2)||1;
    const fh = sorted.slice(0,mid).reduce((s,t)=>s+t.amount,0);
    const sh = sorted.slice(mid).reduce((s,t)=>s+t.amount,0);
    const procurement = purchaseRows.filter(r=>r.competitor===name).reduce((s,r)=>s+r.amount,0);
    competitorStats[name] = {
      customers: companiesSet.size, revenue,
      avgDeal: rows.length ? revenue/rows.length : 0,
      growth: fh>0 ? ((sh-fh)/fh)*100 : 0,
      procurement,
    };
  });

  const allCompanies = Object.values(companyMaster);
  const marketSize = allCompanies.reduce((s,c)=>s+c.totalPurchases,0);
  const totalTxns = allCompanies.reduce((s,c)=>s+c.count,0);
  const next30 = allCompanies.filter(c=> (c.predictedNextPurchase-now)/86400000 <= 30 && (c.predictedNextPurchase-now)/86400000 >= -5).length;
  marketTotals = {
    uniqueCompanies: allCompanies.length,
    marketSize, avgDeal: totalTxns? marketSize/totalTxns : 0,
    predictedOrdersNext30: next30,
  };

  const monthMap = {};
  saleRows.forEach(r=>{
    const key = r.date.getFullYear()+'-'+String(r.date.getMonth()+1).padStart(2,'0');
    monthMap[key] = (monthMap[key]||0) + r.amount;
  });
  monthlyTrend = Object.entries(monthMap).sort((a,b)=> a[0]<b[0]?-1:1).slice(-8);

  processed = true;
  currentView = 'executive';
  render();
}

function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
function fmtCurrency(v){
  if(v>=10000000) return '₹'+(v/10000000).toFixed(2)+' Cr';
  if(v>=100000) return '₹'+(v/100000).toFixed(1)+'L';
  return '₹'+Math.round(v).toLocaleString('en-IN');
}
function fmtDate(d){ return d ? d.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—'; }

function chartColors(){
  const dark = document.documentElement.getAttribute('data-theme')==='dark';
  return {
    primary: dark ? '#4A90D9' : '#1B4F8C',
    primaryFill: dark ? 'rgba(74,144,217,0.15)' : 'rgba(27,79,140,0.08)',
    secondary: dark ? '#52C57F' : '#2F8F5B',
    grid: dark ? '#243042' : '#E5E9EF',
    text: dark ? '#8B97A8' : '#6B7686',
    palette: ['#1B4F8C','#2F8F5B','#8A5A0B','#A3372D','#6B5CA5','#3D8FA6'],
  };
}

