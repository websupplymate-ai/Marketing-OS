    <div class="topbar"><div><h1 class="page-title">Competitors</h1>
      <p class="muted" style="margin:4px 0 0;font-size:13px;"><span class="num">${names.length}</span> sources tracked</p></div></div>
    <div style="display:flex;gap:14px;">
